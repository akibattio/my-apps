# このファイルを .env にコピーして、各自のキーを入れる
# .env 本体は .gitignore で除外されるのでGitHubには上がらない

# Gemini API（記事生成） https://aistudio.google.com
GEMINI_API_KEY=

# Unsplash API（画像取得） https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# WordPress 投稿先
WP_URL=
WP_USERNAME=
WP_APP_PASSWORD=

# Tavily API（Webリサーチ） https://tavily.com
TAVILY_API_KEY=
