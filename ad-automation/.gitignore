# シークレット（絶対にコミットしない）
.env
.env.*
!.env.example
secrets/
*.pem
*.key
client_secret*.json
*credentials*.json
# トークンを「ファイルとして」保存した場合の保険（.txt/.json のみ。.py 等の実装は対象外）
*token*.txt
*token*.json

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/

# 取得データ・生成物（個社の実データはリポジトリに残さない）
data/*.csv
data/*.json
!data/samples/
out/
*.log

# OS / エディタ
.DS_Store
.vscode/
.idea/

# コンソールの実データ（個社数値・Git管理外）
console/data.json
console/daily.json
console/audit.json
console/monthly.json

# 実行ログ
logs/
