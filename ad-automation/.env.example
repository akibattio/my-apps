# ソフコミ 広告運用自動化 — 環境変数テンプレート
# 使い方: このファイルを .env にコピーし、実値を入れる。.env は Git 管理外（.gitignore 済）。
# ⚠️ 実トークンをこのファイル（.env.example）に書かないこと。ここは「変数名の見本」専用。

# ===== Meta =====
# 自社テスト用（システムユーザートークン・60日）
SOFCOM_META_AD_ACCOUNT_ID=act_xxxxxxxxxx
SOFCOM_META_SYSTEM_USER_TOKEN=

RICELOG_META_AD_ACCOUNT_ID=
# テスト段階（手動OAuth・60日失効）
RICELOG_META_ACCESS_TOKEN=
# 無人運用（Routines）用・組織所有の無期限トークン
RICELOG_META_SYSTEM_USER_TOKEN=

# ===== Google Ads（申請が下りてから）=====
# MCCのカスタマーID（ハイフン無し）
GOOGLE_LOGIN_CUSTOMER_ID=
# クライアントのカスタマーID（10桁・ハイフン無し）
RICELOG_GOOGLE_CUSTOMER_ID=
# テスト対象＝自社アカウントの10桁カスタマーID（ハイフン無し）
SOFCOM_GOOGLE_CUSTOMER_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# ===== 通知（任意）=====
SLACK_WEBHOOK_URL=
SLACK_APPROVAL_CHANNEL=
