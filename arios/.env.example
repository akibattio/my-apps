# Supabase 接続情報（プロジェクト作成後に設定）
# Supabase ダッシュボード → Project Settings → API / Database から取得
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# サーバー側専用（絶対にクライアントへ出さない）
SUPABASE_SERVICE_ROLE_KEY=

# マイグレーション適用用（npm run migrate で使用）
# Supabase ダッシュボード → Project Settings → Database → Connection string → URI
# 例: postgresql://postgres:<DB-PASSWORD>@db.<ref>.supabase.co:5432/postgres
SUPABASE_DB_URL=
